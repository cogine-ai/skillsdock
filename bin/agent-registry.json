{
  "meta": {
    "version": 1,
    "referenceSource": "Pattern-seeded from public multi-agent conventions (including vercel-labs/skills) and curated for SkillsDock.",
    "referenceDate": "2026-02-24",
    "note": "This registry is a local curated snapshot. SkillsDock does not fetch agent paths from network at runtime."
  },
  "agents": [
    {
      "id": "openclaw",
      "displayName": "OpenClaw",
      "scopes": {
        "user": {
          "source": { "path": "~/.openclaw/skills", "format": "openclaw-md", "optional": true },
          "target": { "path": "~/.openclaw/skills", "format": "openclaw-md", "layout": "flat", "extension": ".md" }
        },
        "project": {
          "source": { "path": "${projectRoot}/skills", "format": "openclaw-md", "optional": true },
          "target": { "path": "${projectRoot}/skills", "format": "openclaw-md", "layout": "flat", "extension": ".md" }
        }
      }
    },
